DJANGO_SETTINGS_MODULE=firstbrief.settings.development
DJANGO_ENV=development
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=development-only-change-me
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000
DATABASE_URL=postgresql://firstbrief:firstbrief@localhost:5432/firstbrief
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
FIRSTBRIEF_SITE_TIMEZONE=Europe/London
LOG_LEVEL=INFO
FIRSTBRIEF_LOCAL_AUTH_ENABLED=true
FIRSTBRIEF_EXTERNAL_AUTH_BACKEND=
# Development only; omit to avoid creating a seeded administrator.
FIRSTBRIEF_DEVELOPMENT_ADMIN_PASSWORD=
